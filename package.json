{
  "name": "docs-version-deploy",
  "version": "1.0.0",
  "description": "Deploy versioned static documentation to any GitHub repository",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "scripts": {
    "test": "npm run build && npx vitest run --reporter verbose --coverage",
    "format": "prettier --write **/*.{js,ts}",
    "format:check": "prettier --check **/*.{js,ts}",
    "lint": "eslint src/**/*.ts",
    "build": "npm run build:scripts && npm run build:assets && npm run build:action",
    "build:assets": "tsup --config tsup.assets.config.ts && node dist/scripts/build-assets.js",
    "build:scripts": "tsup --config tsup.scripts.config.ts",
    "build:action": "tsup --config tsup.action.config.ts",
    "docs": "npx typedoc",
    "prepare": "is-ci || husky"
  },
  "files": [
    "dist/*",
    "CHANGELOG.md"
  ],
  "keywords": [
    "docs-version-deploy"
  ],
  "author": "Yuki_akai",
  "homepage": "https://github.com/yukiakai212/docs-version-deploy",
  "funding": "https://github.com/sponsors/yukiakai212",
  "engines": {
    "node": ">= 16"
  },
  "maintainers": [
    {
      "name": "Yuki_akai",
      "homepage": "https://github.com/yukiakai212"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yukiakai212/docs-version-deploy.git"
  },
  "bugs": {
    "url": "https://github.com/yukiakai212/docs-version-deploy/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.30.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.0.10",
    "@vitest/coverage-v8": "^4.0.15",
    "dotenv": "^17.0.1",
    "eslint": "^9.30.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.1",
    "tsx": "^4.20.3",
    "typedoc": "^0.28.9",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2",
    "@yukiakai/actions-git": "^1.0.2",
    "@yukiakai/find-up": "^1.1.7",
    "@yukiakai/path-extras": "^1.0.0",
    "@yukiakai/zod-extras": "^1.0.0",
    "fs-extra": "^11.3.5",
    "pathe": "^2.0.3",
    "zod": "^4.3.6"
  }
}
